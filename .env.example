# --- WP Updater configuration -------------------------------------------------
# Copy this file to ".env" and adjust. All values are optional; the GUI can
# edit scheduler + SMTP settings later (Settings page).

# Local timezone for the scheduler (e.g. Europe/Zagreb, UTC).
TZ=UTC

# Host port to expose the dashboard on.
WPUPDATER_PORT=8090

# Flask session signing key — set to a long random string.
WPUPDATER_SECRET_KEY=replace-with-a-long-random-string

# Optional HTTP basic auth in front of the dashboard (leave blank to disable).
WPUPDATER_USER=
WPUPDATER_PASSWORD=

# Set to "false" only if a monitored site uses a self-signed certificate.
WPUPDATER_VERIFY_TLS=true
WPUPDATER_REQUEST_TIMEOUT=30

# Daily automatic scan (24h clock, local time).
WPUPDATER_SCAN_ENABLED=true
WPUPDATER_SCAN_HOUR=6
WPUPDATER_SCAN_MINUTE=0

# SMTP for email reports (can also be set in the GUI later).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
# Comma-separated dashboard report recipients.
REPORT_RECIPIENTS=
